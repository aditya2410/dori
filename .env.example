# ─── Supabase ────────────────────────────────────────────────
# From: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
# NEVER expose this on the client — server routes only
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# ─── Razorpay ─────────────────────────────────────────────────
# From: https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=<your-razorpay-secret>
# From: https://dashboard.razorpay.com/app/webhooks
RAZORPAY_WEBHOOK_SECRET=<your-webhook-secret>

# ─── Resend ───────────────────────────────────────────────────
# From: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Verified sender address. Use 'onboarding@resend.dev' for local testing.
RESEND_FROM_EMAIL=DORI <orders@yourdomain.com>

# ─── Shipping ────────────────────────────────────────────────
# Fixed shipping cost in paise (150 Rs = 15000 paise). Change to adjust.
SHIPPING_PAISE=15000

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Used in Resend email links and Razorpay callback URLs
# Set to your production URL on Vercel, e.g. https://dorijaipur.in

# ─── Social & Contact ─────────────────────────────────────────
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_PINTEREST_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_CONTACT_EMAIL=hello@dorijaipur.in
# Private delivery address — shown nowhere on the site, only used server-side by Resend
CONTACT_NOTIFICATION_EMAIL=
